# FrankenPHP / Caddy configuration for Coffer.
#
# Serves the Laravel public/ directory over plain HTTP on the port given by
# SERVER_NAME (default :8080). The expectation for self-hosting is that a
# reverse proxy in front terminates TLS. To let FrankenPHP handle HTTPS
# directly instead, set SERVER_NAME to your domain and publish ports 80/443.

{
	{$CADDY_GLOBAL_OPTIONS}

	frankenphp

	# No automatic HTTPS by default (served behind a proxy on a bare port).
	auto_https off
}

{$SERVER_NAME:":8080"} {
	root /app/public
	encode zstd br gzip

	# Marks every request so PHP file responses skip their body and name the file (relative to the storage root) in
	# an X-Accel-Redirect response header instead. Setting these here also overrides any client-supplied values.
	request_header X-Sendfile-Type x-accel-redirect
	request_header X-Accel-Mapping {$COFFER_STORAGE_PATH:/data/shares}/=/

	# Catches responses carrying X-Accel-Redirect and serves the named file straight from disk (sendfile, HTTP range
	# support), so file bytes never flow through PHP.
	intercept {
		@accel header X-Accel-Redirect *
		handle_response @accel {
			root {$COFFER_STORAGE_PATH:/data/shares}
			rewrite * {resp.header.X-Accel-Redirect}
			method * GET
			header -X-Accel-Redirect
			file_server
		}
	}

	# Serves static files and routes everything else through index.php.
	php_server

	{$CADDY_SERVER_EXTRA_DIRECTIVES}
}
