{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vp build",
        "dev": "vp dev",
        "lint": "NODE_OPTIONS='--experimental-strip-types' vp fmt resources/ && prettier --write \"resources/views/**/*.blade.php\"",
        "test:lint": "NODE_OPTIONS='--experimental-strip-types' vp fmt --check resources/ && prettier --check \"resources/views/**/*.blade.php\""
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.1.11",
        "concurrently": "^10.0.3",
        "laravel-vite-plugin": "^3.1",
        "npm-check-updates": "^22.0.1",
        "playwright": "^1.61.1",
        "prettier": "^3.8.4",
        "prettier-plugin-blade": "^3.1.6",
        "prettier-plugin-tailwindcss": "^0.7.4",
        "tailwindcss": "^4.0.7",
        "vite": "npm:@voidzero-dev/vite-plus-core@latest",
        "vite-plus": "latest"
    },
    "overrides": {
        "vite": "npm:@voidzero-dev/vite-plus-core@latest",
        "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "4.9.5",
        "@tailwindcss/oxide-linux-x64-gnu": "^4.0.1",
        "lightningcss-linux-x64-gnu": "^1.29.1"
    }
}
