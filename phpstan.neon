includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/calebdw/larastan-livewire/extension.neon
    - vendor/nesbot/carbon/extension.neon
    - phar://phpstan.phar/conf/bleedingEdge.neon

parameters:
    paths:
        - app
        - bootstrap/app.php
        - config
        - database
        - public
        - resources/views
        - routes

    excludePaths:
        - resources/views/flux

    level: max

    tmpDir: /tmp/phpstan
