# Coffer - self-hosting configuration.
#
# Copy this file to .env, fill in the values in the two "Required" sections
# below, then run `docker compose up -d`. Everything after that is optional:
# sensible production defaults are baked into the image.

# ---------------------------------------------------------------------------
# Required - application
# ---------------------------------------------------------------------------

# Encryption key. Generate it once and keep it (changing it invalidates any
# data already encrypted):
#   docker compose run --rm app php artisan key:generate --show
APP_KEY=

# The public URL people reach Coffer on. Used for generated links and for the
# GitHub OAuth callback ({APP_URL}/auth/github/callback).
APP_URL=https://files.example.com

# ---------------------------------------------------------------------------
# Required - GitHub sign-in (the only way to authenticate)
# ---------------------------------------------------------------------------
# Coffer has no passwords. People sign in with GitHub, and access is limited to
# members of one GitHub organization. Register a GitHub OAuth App (see the
# README), set its Authorization callback URL to {APP_URL}/auth/github/callback,
# and paste its credentials below. GITHUB_ORG is the organization whose members
# may sign in: organization OWNERS become Coffer administrators, every other
# member becomes a regular user. The first owner to sign in becomes the first
# admin (there is no setup screen). If the organization restricts third-party
# OAuth apps, an owner must approve this app once so member-vs-owner roles are
# visible.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ORG=

# ---------------------------------------------------------------------------
# Optional - branding
# ---------------------------------------------------------------------------
# Name shown in the UI. The image already defaults this to "Coffer".
# APP_NAME="Coffer"

# ---------------------------------------------------------------------------
# Optional - networking
# ---------------------------------------------------------------------------
# Host port published for the web app. The container always listens on 8080
# internally; this maps a host port onto it. Point your reverse proxy here.
# COFFER_HTTP_PORT=8777

# Listen address for the built-in server. The default is plain HTTP on :8080,
# meant to sit behind a TLS-terminating reverse proxy. To let the container
# serve HTTPS itself, set this to your domain and publish ports 80/443 in
# docker-compose.yml.
# SERVER_NAME=:8080

# ---------------------------------------------------------------------------
# Optional - file storage
# ---------------------------------------------------------------------------
# Coffer stores files on the local filesystem. Every share lives in its own
# directory under COFFER_STORAGE_PATH (the /data/shares volume by default). To
# put a share on a different physical disk, mount that disk under /data/shares
# in docker-compose.yml and point the share at it in the admin UI.
# COFFER_STORAGE_PATH=/data/shares

# Largest single uploaded file in bytes (0 = unlimited). Uploads stream through
# the app, so to accept files larger than ~2 GB also raise the PHP/proxy limits
# (see the Dockerfile and docker/Caddyfile).
# COFFER_MAX_FILE_SIZE=0

# Retention windows for the daily cleanup jobs: how long deleted items stay in
# the recycle bin (days), how long generated zip archives linger (hours), and
# how long share activity is kept (days; 0 = keep forever).
# COFFER_TRASH_DAYS=30
# COFFER_ZIP_TTL_HOURS=24
# COFFER_ACTIVITY_DAYS=90

# ---------------------------------------------------------------------------
# Optional - runtime
# ---------------------------------------------------------------------------
# Run database migrations automatically on container start. Set to false to run
# `php artisan migrate` yourself.
# RUN_MIGRATIONS=true

# The image also sets production-ready defaults for APP_ENV, APP_DEBUG, the
# SQLite database, and the file/database drivers used for cache, sessions, and
# the queue. Override those only if you know you need to.
