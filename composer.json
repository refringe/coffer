{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "refringe/coffer",
    "type": "project",
    "description": "",
    "keywords": [],
    "license": "MPL-2.0",
    "require": {
        "php": "^8.5",
        "laravel/framework": "^13.7",
        "laravel/socialite": "^5.28",
        "livewire/blaze": "^1.0",
        "livewire/flux": "^2.14.1",
        "livewire/livewire": "^4.1",
        "nunomaduro/essentials": "^1.2"
    },
    "require-dev": {
        "calebdw/larastan-livewire": "^2.5",
        "driftingly/rector-laravel": "^2.4.0",
        "fakerphp/faker": "^1.24.1",
        "larastan/larastan": "^3.9.6",
        "laravel/boost": "^2.4.8",
        "laravel/chisel": "^0.1.0",
        "laravel/pail": "^1.2.6",
        "laravel/pao": "^1.0.6",
        "laravel/pint": "^1.29.1",
        "laravel/tinker": "^3.0.2",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.4",
        "pestphp/pest": "^4.7.0",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-browser": "^4.3",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "rector/rector": "^2.4",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "rector": [
            "./vendor/bin/rector process --config=rector.php"
        ],
        "rector:check": [
            "./vendor/bin/rector process --dry-run --config=rector.php"
        ],
        "coverage": [
            "./vendor/bin/pest --type-coverage --min=100"
        ],
        "phpstan": [
            "./vendor/bin/phpstan analyse --memory-limit=512M"
        ],
        "pint": [
            "./vendor/bin/pint --config pint.json"
        ],
        "pint:check": [
            "./vendor/bin/pint --config pint.json --test"
        ],
        "spell": [
            "typos . --config ./typos.toml && echo 'DONE'"
        ],
        "test": [
            "./vendor/bin/pest --parallel --compact --exclude-group=browser",
            "npm install playwright@latest",
            "npx playwright install",
            "./vendor/bin/pest --parallel --compact --group=browser"
        ],
        "format": [
            "@pint",
            "npm run lint"
        ],
        "format:check": [
            "@pint:check",
            "npm run test:lint"
        ],
        "lint": [
            "@rector",
            "@phpstan",
            "@coverage",
            "@spell"
        ],
        "lint:check": [
            "@rector:check",
            "@phpstan",
            "@coverage",
            "@spell"
        ],
        "sendit": [
            "Composer\\Config::disableProcessTimeout",
            "@format",
            "@lint",
            "@test"
        ],
        "update:requirements": [
            "composer bump",
            "npx npm-check-updates -u"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan vendor:publish --tag=livewire:assets --ansi --force",
            "@php artisan boost:update --ansi",
            "@php artisan clear"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --queue=default --tries=2 --timeout=900\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [],
            "installer": {
                "post-create-project": []
            }
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
