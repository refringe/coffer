APP_NAME=Coffer
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://coffer.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Only send the session cookie over HTTPS. Coffer is served over TLS
# (Herd locally, a TLS-terminating proxy in production); set to false only if
# you intentionally serve over plain HTTP.
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Authentication is GitHub-only. Register a GitHub OAuth App with an Authorization
# callback URL of {APP_URL}/auth/github/callback, then set the values below.
# GITHUB_ORG is the organization whose members may sign in: organization owners
# become Coffer administrators, all other members become regular users. (If the
# org restricts third-party OAuth apps, an owner must approve this app once so the
# read:org scope can see member-vs-owner roles.)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ORG=

# Share files are stored on the local filesystem. Each share lives in its own
# directory; COFFER_STORAGE_PATH is the base directory new shares default under
# (an administrator may point a share at any absolute path in the admin UI).
# Defaults to storage/app/shares when unset.
# COFFER_STORAGE_PATH=/data/shares

# Upload size limit in bytes (0 = unlimited) and retention windows for the daily
# cleanup jobs: recycle bin (days), zip archives (hours), stalled uploads (hours),
# activity log (days).
COFFER_MAX_FILE_SIZE=0
COFFER_TRASH_DAYS=30
COFFER_ZIP_TTL_HOURS=24
COFFER_UPLOAD_TTL_HOURS=48
COFFER_ACTIVITY_DAYS=90

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME="Coffer"
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@coffer.test"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
